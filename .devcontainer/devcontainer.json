{
  "name": "C++ (Debian 12)",
  "build": { "dockerfile": "Dockerfile" },
  "customizations": {
    "vscode": {
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "vadimcn.vscode-lldb",
        "ms-vscode.cmake-tools"
      ]
    }
  },
  "postCreateCommand": "g++ --version && clangd --version && cmake --version && ninja --version && lldb --version",
  "remoteUser": "vscode"
}
